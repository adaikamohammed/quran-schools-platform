// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── المستخدمون والأدوار ────────────────────────────────────
model User {
  id           String    @id @default(uuid())
  schoolId     String
  email        String    @unique
  passwordHash String?
  displayName  String
  role         String    // 'super_admin', 'principal', 'teacher', 'parent'
  photoURL     String?
  phone        String?
  gender       String?   // 'ذكر' | 'أنثى'
  joinDate     String?   // YYYY-MM-DD
  isActive     Boolean   @default(true)
  
  // للمعلمين:
  groupName    String?
  bio          String?
  certifications String?
  
  // للآباء (يمكن تخزين الـ IDs كـ JSON array لتسهيل البحث البسيط أو جدول وسيط)
  studentIds   String[]  // Prisma supports scalar arrays in PostgreSQL
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime? 
  
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  @@index([schoolId])
}

// ─── المدرسة ────────────────────────────────────────────────
model School {
  id              String    @id @default(uuid())
  name            String
  city            String
  country         String
  directorName    String
  email           String
  phone           String?
  logoURL         String?
  seasonStartDate String?   // YYYY-MM-DD
  
  settings        Json      // SchoolSettings object mapped to JSON
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  users           User[]
  students        Student[]
  sessions        DailySession[]
  surahProgresses SurahProgress[]
  payments        Payment[]
  reports         DailyReport[]
  meetings        Meeting[]
  preRegistrations PreRegistration[]
}

// ─── الطلاب ─────────────────────────────────────────────────
model Student {
  id                      String    @id @default(uuid())
  schoolId                String
  teacherId               String
  groupName               String
  fullName                String
  gender                  String    // 'ذكر' أو 'أنثى'
  birthDate               String
  educationalLevel        String?
  guardianName            String
  phone1                  String
  phone2                  String?
  photoURL                String?
  registrationDate        String
  status                  String    // StudentStatus
  subscriptionTier        String    // SubscriptionTier
  memorizedSurahsCount    Int       @default(0)
  dailyMemorizationAmount String    // MemorizationAmount
  pageNumber              String?
  notes                   String?
  actionReason            String?

  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime? 

  school                  School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  covenants               Covenant[]
  expulsionHistory        ExpulsionRecord[]
  transferHistory         TransferRecord[]
  dailyRecords            DailyRecord[]
  surahProgresses         SurahProgress[]
  payments                Payment[]

  @@index([schoolId])
  @@index([teacherId])
}

// ─── العهود والعقوبات ────────────────────────────────────────
model Covenant {
  id                   String    @id @default(uuid())
  studentId            String
  type                 String    // CovenantType
  text                 String
  status               String    // CovenantStatus
  card                 String    // CovenantCard
  date                 String
  absenceDays          Int?
  writtenPenalty       String?
  dueDate              String?
  compensationSessions Int?
  compensationDate     String?
  isCompensated        Boolean?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  student              Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  @@index([studentId])
}

model ExpulsionRecord {
  id          String   @id @default(uuid())
  studentId   String
  date        String
  reason      String
  
  createdAt   DateTime @default(now())
  deletedAt   DateTime?
  
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  @@index([studentId])
}

model TransferRecord {
  id               String   @id @default(uuid())
  studentId        String
  date             String
  fromTeacherId    String
  fromTeacherName  String?
  fromGroupName    String
  toTeacherId      String
  toTeacherName    String?
  toGroupName      String
  reason           String

  createdAt        DateTime @default(now())
  deletedAt        DateTime?
  
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  @@index([studentId])
}

// ─── الحصص اليومية ──────────────────────────────────────────
model DailySession {
  id                   String    @id @default(uuid())
  schoolId             String
  teacherId            String
  date                 String    // YYYY-MM-DD
  sessionNumber        Int       // 1 or 2
  sessionType          String    // SessionType
  
  teacherAbsenceReason String?
  substituteTeacher    String?
  activityType         String?
  activityDescription  String?
  surahId              Int?
  fromVerse            Int?
  toVerse              Int?
  isReview             Boolean?
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  school               School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  records              DailyRecord[]

  @@index([schoolId])
  @@index([teacherId])
  @@unique([date, sessionNumber, teacherId, schoolId]) // لمنع التكرار
}

model DailyRecord {
  id              String    @id @default(uuid())
  sessionId       String
  studentId       String
  
  attendance      String
  memorization    String?
  surahId         Int?
  fromVerse       Int?
  toVerse         Int?
  review          Boolean?
  behavior        String?
  notes           String?
  
  // تلقين
  talqinSurahId   Int?
  talqinFromVerse Int?
  talqinToVerse   Int?
  // تسميع
  tasmieSurahId   Int?
  tasmieFromVerse Int?
  tasmieToVerse   Int?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  session         DailySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student         Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([studentId])
  @@unique([sessionId, studentId]) // طالب واحد لكل حصة
}

// ─── متابعة الحفظ ────────────────────────────────────────────
model SurahProgress {
  id              String    @id @default(uuid())
  studentId       String
  schoolId        String
  surahId         Int
  surahName       String
  status          String
  fromVerse       Int?
  toVerse         Int?
  totalVerses     Int?
  startDate       String?
  completionDate  String?
  retakeCount     Int?      @default(0)
  notes           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
}

// ─── الاشتراكات ───────────────────────────────────────────
model Payment {
  id              String    @id @default(uuid())
  schoolId        String
  studentId       String
  amount          Float
  date            String    // تاريخ الفصل الدراسي
  status          String    // PaymentStatus
  paidAt          String?
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
}

// ─── التسجيلات المسبقة ──────────────────────────────────────
model PreRegistration {
  id               String    @id @default(uuid())
  schoolId         String
  requestedAt      String
  fullName         String
  gender           String
  birthDate        String
  educationalLevel String?
  guardianName     String?
  phone1           String
  phone2           String?
  address          String?
  status           String
  notes            String?
  photoURL         String?
  approvedById     String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  school           School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

// ─── التقارير اليومية ────────────────────────────────────────
model DailyReport {
  id                  String    @id @default(uuid())
  schoolId            String
  teacherId           String
  date                String
  note                String
  timestamp           String
  authorName          String
  category            String
  status              String
  adminNotes          String?
  isPinned            Boolean   @default(false)
  priority            String?
  hasNewReply         Boolean?  @default(false)
  isManagementMessage Boolean?  @default(false)
  recipientId         String?
  isReadByRecipient   Boolean?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  school              School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([teacherId])
}

// ─── الاجتماعات ───────────────────────────────────────────
model Meeting {
  id              String    @id @default(uuid())
  schoolId        String
  title           String
  date            String
  timestamp       String
  attendance      Json      // Map of user status
  foodProvided    Boolean   @default(false)
  foodDetails     String?
  topics          Json      // Array of MeetingTopic
  status          String
  createdBy       String

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}
